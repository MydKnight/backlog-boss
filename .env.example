# Steam
STEAM_API_KEY=
STEAM_ID=

# IGDB / Twitch
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Ollama
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# App
DATABASE_PATH=./data/backlog.db
PORT=3000
NODE_ENV=development

# Auth (Phase 8)
# Set to the email address configured in Cloudflare Access for the owner account.
# On startup, the existing owner row is linked to this email so CF auth works.
OWNER_EMAIL=
