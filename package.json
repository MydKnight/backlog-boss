{
  "name": "backlog-boss",
  "version": "1.0.0",
  "description": "Personal game backlog manager with taste-aware suggestions",
  "type": "module",
  "main": "src/server/index.js",
  "scripts": {
    "start": "node src/server/index.js",
    "dev": "concurrently -n server,client -c cyan,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon --ignore data/ --ignore '*.db' --ignore '*.db-wal' --ignore '*.db-shm' src/server/index.js",
    "dev:client": "vite",
    "build": "vite build"
  },
  "dependencies": {
    "dotenv": "^16.4.1",
    "express": "^4.18.3",
    "p-queue": "^8.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  }
}
